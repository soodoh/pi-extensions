{
	"name": "pi-extensions",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.12",
	"workspaces": [
		"packages/*"
	],
	"pi": {
		"extensions": [
			"./packages/auto-session-name/index.ts",
			"./packages/prompt-suggester/src/index.ts",
			"./packages/shared-prompt-history/index.ts",
			"./packages/statusline/index.ts",
			"./packages/workflows/index.ts"
		]
	},
	"scripts": {
		"build": "turbo run build",
		"check": "biome check .",
		"check:write": "biome check --write .",
		"ci": "bun run check && bun run typecheck && bun run test:typecheck && bun run test:coverage",
		"prepare": "bun run prepare:lefthook",
		"test": "turbo run test",
		"test:coverage": "vitest run --coverage",
		"test:typecheck": "tsc --noEmit --project tsconfig.test.json",
		"typecheck": "turbo run typecheck",
		"prepare:lefthook": "node scripts/prepare-lefthook.cjs",
		"test:coverage:html": "vitest run --coverage --coverage.reporter=text --coverage.reporter=lcov --coverage.reporter=html"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.2.0",
		"@commitlint/cli": "^20.0.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@mariozechner/pi-agent-core": "*",
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*",
		"@types/node": "^24.3.0",
		"@vitest/coverage-v8": "^4.0.0",
		"lefthook": "^1.13.0",
		"turbo": "^2.5.0",
		"typescript": "^5.7.3",
		"vitest": "^4.0.0"
	}
}
