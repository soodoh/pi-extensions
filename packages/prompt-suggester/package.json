{
	"name": "prompt-suggester",
	"version": "0.1.0",
	"type": "module",
	"description": "Pi extension that suggests likely next prompts from session and project context.",
	"main": "src/index.ts",
	"files": [
		"src",
		"prompt-suggester.config.json",
		"README.md"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"dependencies": {
		"typebox": "^1.1.37"
	},
	"peerDependencies": {
		"@mariozechner/pi-agent-core": "*",
		"@mariozechner/pi-ai": "*",
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"scripts": {
		"build": "tsc --noEmit",
		"test": "vitest run --root ../.. packages/prompt-suggester --passWithNoTests",
		"typecheck": "tsc --noEmit"
	}
}
