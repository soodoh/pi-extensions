{
	"name": "shared-prompt-history",
	"version": "0.1.0",
	"type": "module",
	"description": "Pi extension that shares prompt history across sessions.",
	"main": "index.ts",
	"files": [
		"*.ts",
		"README.md"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@mariozechner/pi-tui": "*"
	},
	"scripts": {
		"build": "tsc --noEmit",
		"test": "vitest run --root ../.. packages/shared-prompt-history",
		"typecheck": "tsc --noEmit"
	}
}
