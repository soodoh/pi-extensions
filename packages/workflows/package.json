{
	"name": "workflows",
	"version": "0.1.0",
	"type": "module",
	"description": "Deterministic YAML-defined workflows for Pi with Plannotator and subagent review loops.",
	"main": "index.ts",
	"files": [
		"index.ts",
		"src/config-loader.ts",
		"src/model-policy.ts",
		"src/pi-events.ts",
		"src/plannotator.ts",
		"src/runner.ts",
		"src/store.ts",
		"src/utils.ts",
		"src/workflow-types.ts",
		"src/yaml-loader.ts",
		"commands",
		"workflows",
		"README.md"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"prompts": [
			"./commands"
		],
		"skills": [],
		"themes": []
	},
	"dependencies": {
		"typebox": "^1.1.37",
		"yaml": "^2.8.3"
	},
	"scripts": {
		"build": "tsc --noEmit",
		"test": "vitest run --root ../.. packages/workflows",
		"typecheck": "tsc --noEmit"
