{
	"exclude": [
		"**/*.test.ts",
		"**/*.spec.ts",
		"coverage",
		"dist",
		"node_modules"
	],
	"compilerOptions": {
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"lib": ["ES2022", "DOM"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"types": ["node"]
	}
}
